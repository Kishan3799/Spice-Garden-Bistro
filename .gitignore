logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Netlify ────────────────────────────────────────────────────
.netlify/

